{
  "entities": {
    "Product": {
      "title": "Товар",
      "description": "Товар на складі",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "isArchived": { "type": "boolean" },
        "isDeleted": { "type": "boolean" }
      },
      "required": ["name", "price"]
    },
    "Client": {
      "title": "Клієнт",
      "description": "Клієнтська база",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "address": { "type": "string" },
        "comment": { "type": "string" },
        "isArchived": { "type": "boolean" },
        "isDeleted": { "type": "boolean" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Замовлення",
      "description": "Замовлення клієнта",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Чернетка", "Виконано", "Скасовано"] },
        "delivery": { "type": "string" },
        "manager": { "type": "string" },
        "comment": { "type": "string" },
        "extraCosts": { "type": "number" },
        "isDeleted": { "type": "boolean" }
      },
      "required": ["clientId", "date", "status"]
    },
    "OrderItem": {
      "title": "Позиція замовлення",
      "description": "Товар у замовленні",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "qty": { "type": "number" },
        "price": { "type": "number" },
        "isDeleted": { "type": "boolean" }
      },
      "required": ["orderId", "productId", "qty", "price"]
    },
    "WriteOff": {
      "title": "Списання",
      "description": "Списання товарів",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Чернетка", "Проведено", "Скасовано"] },
        "comment": { "type": "string" },
        "isDeleted": { "type": "boolean" }
      },
      "required": ["date", "status"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Колекція товарів" },
    "clients": { "schema": "Client", "description": "Колекція клієнтів" },
    "orders": { "schema": "Order", "description": "Колекція замовлень" },
    "orderItems": { "schema": "OrderItem", "description": "Колекція позицій замовлень" },
    "purchases": { "schema": "Purchase", "description": "Колекція закупівель" },
    "purchaseItems": { "schema": "PurchaseItem", "description": "Колекція позицій закупівель" },
    "writeOffs": { "schema": "WriteOff", "description": "Колекція списань" },
    "writeOffItems": { "schema": "WriteOffItem", "description": "Колекція позицій списань" },
    "suppliers": { "schema": "Supplier", "description": "Довідник постачальників" },
    "expenses": { "schema": "Expense", "description": "Опервитрати" },
    "technicalSpecs": { "schema": "TechnicalSpec", "description": "Теххарактеристики" },
    "helium": { "schema": "HeliumTank", "description": "Залишки гелію" },
    "users": { "schema": "AppUser", "description": "Користувачі системи" },
    "logs": { "schema": "Log", "description": "Логи дій" }
  }
}
